{
  "name": "trybeacon",
  "version": "0.1.90",
  "description": "The visual planning surface for the coding agent in your terminal.",
  "homepage": "https://trybeacon.sh",
  "license": "Apache-2.0",
  "author": "Wenzo (https://trybeacon.sh)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wenzorithelly/beacon.git"
  },
  "bugs": {
    "url": "https://github.com/wenzorithelly/beacon/issues"
  },
  "bin": {
    "beacon": "dist/bin/beacon.js"
  },
  "files": [
    "dist",
    ".next",
    "public",
    "drizzle",
    "next.config.ts",
    "bun.lock",
    ".claude-plugin/plugin.json",
    "plugin"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cli": "bun scripts/build-cli.ts",
    "build:plugin": "bun scripts/build-plugin.ts",
    "build:release": "rm -rf .next && next build --webpack && rm -rf .next/cache .next/dev && find .next -name '*.js.map' -delete && bun run build:cli && bun run build:plugin",
    "prepublishOnly": "bun run build:release",
    "start": "next start",
    "lint": "eslint",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "db:generate": "drizzle-kit generate",
    "db:generate:deploy": "drizzle-kit generate --config drizzle.deploy.config.ts",
    "db:migrate:deploy": "drizzle-kit migrate --config drizzle.deploy.config.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@libsql/client": "^0.17.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neondatabase/serverless": "^1.1.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tiptap/core": "3.26.1",
    "@tiptap/extension-list": "3.26.1",
    "@tiptap/extension-mention": "3.26.1",
    "@tiptap/extension-underline": "3.26.1",
    "@tiptap/extensions": "3.26.1",
    "@tiptap/markdown": "3.26.1",
    "@tiptap/pm": "3.26.1",
    "@tiptap/react": "3.26.1",
    "@tiptap/starter-kit": "3.26.1",
    "@tiptap/suggestion": "3.26.1",
    "@types/d3-force": "^3.0.10",
    "@xyflow/react": "^12.11.0",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next": "16.2.7",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-diff-view": "^3.3.3",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.77.0",
    "refractor": "^5.0.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.15",
    "@hono/node-server": "1.19.14",
    "esbuild": "0.28.1"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
