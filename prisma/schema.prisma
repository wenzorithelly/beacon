// Juriscan Control App — schema
// Kept Postgres-portable: no `enum` (String + Zod unions) and no scalar lists
// (tags/notes modeled as related rows — SQLite can't store arrays).
// To deploy: flip datasource.provider to "postgresql" and point DATABASE_URL at Neon.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
  // Prisma 7: connection URL lives in prisma.config.ts (Migrate) and the
  // driver adapter in lib/db.ts (runtime). To deploy, switch to "postgresql".
}

/// A unit on the map: a roadmap front/task/subtask OR an architecture feature node.
/// Discriminated by `view`. Self-references for the fronts -> tasks -> subtasks tree.
model Node {
  id         String   @id @default(cuid())
  view       String // "ROADMAP" | "ARCHITECTURE"
  cluster    String? // lane: "EMERGENCY","FRONT_1".. | "AUTH","SEARCH"..
  title      String
  role       String? // one-line technical role
  plain      String? // plain-English description
  status     String   @default("PENDING")
  // ROADMAP: DONE|IN_PROGRESS|PENDING|BLOCKED|CANCELLED|DEPRIORITIZED
  // ARCH:    KEEP|REBUILD|REPLACE|DROP
  priority   Int      @default(2) // 0 critical .. 3 low; deprioritize bumps this
  progress   Int      @default(0) // optional manual override; else derived from children
  x          Float    @default(0) // persisted canvas position
  y          Float    @default(0)
  sourceRef  String? // nullable file:line — FUTURE introspection hook
  externalId String? // FUTURE introspection node id
  source     String   @default("MANUAL") // "MANUAL" | future "INTROSPECTION"

  parentId String?
  parent   Node?   @relation("NodeTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Node[]  @relation("NodeTree")

  tags     Tag[]  @relation("NodeTags")
  notes    Note[]
  bugs     Bug[]
  edgesOut Edge[] @relation("EdgeFrom")
  edgesIn  Edge[] @relation("EdgeTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([view])
  @@index([parentId])
  @@index([cluster])
}

model Note {
  id        String   @id @default(cuid())
  body      String
  nodeId    String
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([nodeId])
}

model Tag {
  id    String @id @default(cuid())
  label String @unique
  color String?
  nodes Node[] @relation("NodeTags") // implicit M:N — Postgres-portable
}

model Edge {
  id     String  @id @default(cuid())
  fromId String
  toId   String
  from   Node    @relation("EdgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to     Node    @relation("EdgeTo", fields: [toId], references: [id], onDelete: Cascade)
  kind   String  @default("DEPENDS") // DEPENDS|CONTAINS|RELATES|REPLACES
  label  String?

  @@unique([fromId, toId, kind])
  @@index([fromId])
  @@index([toId])
}

/// A known issue. Seeded from the proposal's confirmed bugs; a future Sentry
/// adapter upserts here keyed on (source, externalId).
model Bug {
  id         String   @id @default(cuid())
  title      String
  detail     String?
  severity   String   @default("medium") // critical|high|medium|low
  status     String   @default("OPEN") // OPEN|IN_PROGRESS|RESOLVED|WONTFIX
  sourceRef  String? // real file:line
  source     String   @default("MANUAL") // "MANUAL" | future "SENTRY"
  externalId String? // FUTURE Sentry issue id
  nodeId     String?
  node       Node?    @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([nodeId])
  @@index([severity])
  @@index([source, externalId]) // future Sentry upsert lookup
}

// ─────────────────────────────────────────────────────────────────────────────
// Database design map. Models the planned Juriscan v2 backend schema
// (FastAPI + SQLAlchemy + Alembic): tables, columns, FK relationships, and which
// API endpoints touch which tables. A future introspection job can upsert these
// from the SQLAlchemy metadata + FastAPI routes (keyed on name/path).
// ─────────────────────────────────────────────────────────────────────────────

model DbTable {
  id          String  @id @default(cuid())
  name        String  @unique // e.g. "firms"
  domain      String? // grouping lane: "auth","firms","search"...
  description String?
  source      String  @default("MANUAL") // "MANUAL" | "INTROSPECTION" (live from code)
  x           Float   @default(0)
  y           Float   @default(0)

  columns DbColumn[]
  fksOut  DbRelation[]    @relation("FkFrom")
  fksIn   DbRelation[]    @relation("FkTo")
  usages  EndpointTable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([domain])
}

model DbColumn {
  id       String  @id @default(cuid())
  tableId  String
  table    DbTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  name     String
  type     String // SQLAlchemy/PG type, e.g. "UUID", "TEXT", "vector(1536)"
  isPk     Boolean @default(false)
  isFk     Boolean @default(false)
  nullable Boolean @default(true)
  note     String?
  ord      Int     @default(0) // display order

  @@unique([tableId, name])
  @@index([tableId])
}

model DbRelation {
  id          String  @id @default(cuid())
  fromTableId String
  toTableId   String
  fromTable   DbTable @relation("FkFrom", fields: [fromTableId], references: [id], onDelete: Cascade)
  toTable     DbTable @relation("FkTo", fields: [toTableId], references: [id], onDelete: Cascade)
  fromColumn  String // FK column on fromTable
  toColumn    String // referenced column on toTable (usually its PK)
  label       String?

  @@index([fromTableId])
  @@index([toTableId])
}

model Endpoint {
  id          String  @id @default(cuid())
  method      String // GET|POST|PUT|PATCH|DELETE
  path        String // /firms/{id}/members
  domain      String?
  description String?
  source      String  @default("MANUAL") // "MANUAL" | "INTROSPECTION"
  x           Float   @default(0)
  y           Float   @default(0)

  tables EndpointTable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([method, path])
  @@index([domain])
}

model EndpointTable {
  id         String   @id @default(cuid())
  endpointId String
  tableId    String
  endpoint   Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  table      DbTable  @relation(fields: [tableId], references: [id], onDelete: Cascade)
  access     String   @default("read") // read|write|read-write

  @@unique([endpointId, tableId])
  @@index([tableId])
}

/// Single-row counter bumped on every introspection ingest; clients poll/subscribe
/// to it to live-refresh the maps.
model SyncState {
  id        String   @id @default("singleton")
  version   Int      @default(0)
  updatedAt DateTime @updatedAt
}
