# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# bundled CLI (built for publishing by `bun run build:cli`)
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# local sqlite databases
*.db
*.db-journal
*.db-shm
*.db-wal

# claude code
.claude/

# playwright mcp output (screenshots, traces)
playwright-mcp/
.playwright-mcp/

# superdesign (local design mockups / exploration)
.superdesign/

# local scratch / unrelated experiments
/social_network/
